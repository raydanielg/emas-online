                                            <form action="{{ route('users.toggleStatus', $user) }}" method="POST" style="display:inline;" id="status-form-{{ $user->id }}">
                                                @csrf
                                                @method('PATCH')
                                                <button type="button" class="btn btn-sm btn-{{ $user->status === 'active' ? 'secondary' : 'success' }}" 
                                                        onclick="confirmAction('{{ $user->status === 'active' ? 'Suspend' : 'Activate' }}', 'status-form-{{ $user->id }}')"
                                                        title="{{ $user->status === 'active' ? 'Suspend' : 'Activate' }}">
                                                    <i class="fas fa-{{ $user->status === 'active' ? 'user-slash' : 'user-check' }}"></i>
                                                </button>
                                            </form>

                                            <form action="{{ route('users.destroy', $user) }}" method="POST" style="display:inline;" id="delete-form-{{ $user->id }}">
                                                @csrf
                                                @method('DELETE')
                                                <button type="button" class="btn btn-sm btn-danger" 
                                                        onclick="confirmAction('Delete', 'delete-form-{{ $user->id }}')"
